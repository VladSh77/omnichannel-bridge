<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_conversation_identity_wizard_form" model="ir.ui.view">
        <field name="name">omni.conversation.identity.wizard.form</field>
        <field name="model">omni.conversation.identity.wizard</field>
        <field name="arch" type="xml">
            <form string="Ідентифікувати клієнта">
                <header>
                    <button name="action_search" type="object" string="Пошук у базі" class="btn-primary"/>
                </header>
                <sheet>
                    <field name="search_done" invisible="1"/>
                    <group>
                        <field name="channel_id"/>
                        <field name="search_email" placeholder="Email клієнта (з чату)"/>
                        <field name="search_phone" placeholder="Або телефон"/>
                    </group>
                    <group invisible="not search_done">
                        <field name="found_count"/>
                        <field name="found_partner_ids" widget="many2many_tags" readonly="1"/>
                        <field name="selected_partner_id"
                               domain="[('id', 'in', found_partner_ids)]"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_link_partner" type="object" string="Прив'язати обраного"
                            class="btn-primary" invisible="not search_done or not selected_partner_id"/>
                    <button name="action_open_partner" type="object" string="Відкрити картку"
                            class="btn-secondary" invisible="not search_done"/>
                    <button name="action_create_and_link" type="object" string="Створити нового й прив'язати"
                            class="btn-secondary"/>
                    <button string="Закрити" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_omni_conversation_identity_wizard" model="ir.actions.act_window">
        <field name="name">Ідентифікувати клієнта</field>
        <field name="res_model">omni.conversation.identity.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_omni_conversation_identity_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>

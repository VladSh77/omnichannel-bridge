<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_omnichannel" model="ir.ui.view">
        <field name="name">product.template.form.inherit.omnichannel</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="inside">
                <group string="Chatbot (Omnichannel)" name="omnichannel_product_group">
                    <field name="omni_places_remaining"/>
                    <field name="omni_chat_terms" placeholder="Short terms for the bot: deadlines, what is included, payment rules..."/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

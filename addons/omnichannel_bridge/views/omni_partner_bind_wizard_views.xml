<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_omni_partner_bind_wizard_form" model="ir.ui.view">
        <field name="name">omni.partner.bind.wizard.form</field>
        <field name="model">omni.partner.bind.wizard</field>
        <field name="arch" type="xml">
            <form string="Прив'язати контакт">
                <group>
                    <field name="channel_id" readonly="1"/>
                    <field name="partner_id" options="{'no_create': True, 'no_create_edit': True}"/>
                </group>
                <footer>
                    <button name="action_bind_partner" type="object" string="Прив'язати" class="btn-primary"/>
                    <button string="Скасувати" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_omni_partner_bind_wizard" model="ir.actions.act_window">
        <field name="name">Прив'язати контакт</field>
        <field name="res_model">omni.partner.bind.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_omni_partner_bind_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_ai_job_tree" model="ir.ui.view">
        <field name="name">omni.ai.job.tree</field>
        <field name="model">omni.ai.job</field>
        <field name="arch" type="xml">
            <tree string="AI Jobs" create="false">
                <field name="create_date"/>
                <field name="state"/>
                <field name="provider"/>
                <field name="channel_id"/>
                <field name="partner_id"/>
                <field name="attempt_count"/>
                <field name="max_attempts"/>
                <field name="next_attempt_at"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_ai_job_form" model="ir.ui.view">
        <field name="name">omni.ai.job.form</field>
        <field name="model">omni.ai.job</field>
        <field name="arch" type="xml">
            <form string="AI Job">
                <header>
                    <button name="action_retry" type="object" string="Retry"
                            class="btn-primary" invisible="state not in ('failed','cancelled')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            class="btn-secondary" invisible="state in ('done','failed','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="queued,running,done,failed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="provider"/>
                            <field name="channel_id"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="attempt_count"/>
                            <field name="max_attempts"/>
                            <field name="next_attempt_at"/>
                            <field name="create_date" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="user_text"/>
                    </group>
                    <group>
                        <field name="last_error"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_ai_job" model="ir.actions.act_window">
        <field name="name">AI Jobs</field>
        <field name="res_model">omni.ai.job</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_omni_webhook_event_tree" model="ir.ui.view">
        <field name="name">omni.webhook.event.tree</field>
        <field name="model">omni.webhook.event</field>
        <field name="arch" type="xml">
            <tree string="Webhook Events" create="false">
                <field name="received_at"/>
                <field name="processed_at"/>
                <field name="state"/>
                <field name="provider"/>
                <field name="external_event_id"/>
                <field name="payload_hash"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_webhook_event_form" model="ir.ui.view">
        <field name="name">omni.webhook.event.form</field>
        <field name="model">omni.webhook.event</field>
        <field name="arch" type="xml">
            <form string="Webhook Event">
                <sheet>
                    <group>
                        <group>
                            <field name="provider"/>
                            <field name="external_event_id"/>
                            <field name="payload_hash"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="received_at"/>
                            <field name="processed_at"/>
                        </group>
                    </group>
                    <group>
                        <field name="error_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_webhook_event" model="ir.actions.act_window">
        <field name="name">Webhook Events</field>
        <field name="res_model">omni.webhook.event</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_omni_ops_root"
        name="Operations"
        parent="menu_omni_root"
        sequence="40"
    />
    <menuitem
        id="menu_omni_ai_jobs"
        name="AI Jobs"
        parent="menu_omni_ops_root"
        action="action_omni_ai_job"
        sequence="10"
    />
    <menuitem
        id="menu_omni_webhook_events"
        name="Webhook Events"
        parent="menu_omni_ops_root"
        action="action_omni_webhook_event"
        sequence="20"
    />
</odoo>

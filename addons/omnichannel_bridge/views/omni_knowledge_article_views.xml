<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_knowledge_article_tree" model="ir.ui.view">
        <field name="name">omni.knowledge.article.tree</field>
        <field name="model">omni.knowledge.article</field>
        <field name="arch" type="xml">
            <tree>
                <field name="active" string="Активна"/>
                <field name="priority" string="Пріоритет"/>
                <field name="name" string="Назва"/>
                <field name="category" string="Категорія"/>
                <field name="channel_scope" string="Канал"/>
                <field name="source_type" string="Тип джерела"/>
                <field name="editorial_approved" string="Схвалено"/>
                <field name="fact_expires_on" string="Дійсна до"/>
                <field name="source_url" string="URL джерела"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_knowledge_article_form" model="ir.ui.view">
        <field name="name">omni.knowledge.article.form</field>
        <field name="model">omni.knowledge.article</field>
        <field name="arch" type="xml">
            <form string="Стаття бази знань">
                <sheet>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="priority"/>
                            <field name="category"/>
                            <field name="channel_scope"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="source_url"/>
                            <field name="source_type"/>
                            <field name="source_ref"/>
                            <field name="source_timestamp"/>
                            <field name="editorial_approved"/>
                            <field name="fact_expires_on"/>
                        </group>
                    </group>
                    <group>
                        <field name="body"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_knowledge_article" model="ir.actions.act_window">
        <field name="name">Статті бази знань</field>
        <field name="res_model">omni.knowledge.article</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Додайте статтю вручну або оновіть модуль — підвантажаться дані з репозиторію camp (генерований XML).
            </p>
            <p>
                Повний текст таборів і політик у полі <strong>Текст</strong>; колонка URL джерела — для посилання на сайт/PDF.
            </p>
        </field>
    </record>
</odoo>

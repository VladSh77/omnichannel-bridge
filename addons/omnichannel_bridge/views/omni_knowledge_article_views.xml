<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_knowledge_article_tree" model="ir.ui.view">
        <field name="name">omni.knowledge.article.tree</field>
        <field name="model">omni.knowledge.article</field>
        <field name="arch" type="xml">
            <tree>
                <field name="active"/>
                <field name="priority"/>
                <field name="name"/>
                <field name="category"/>
                <field name="channel_scope"/>
                <field name="source_type"/>
                <field name="editorial_approved"/>
                <field name="fact_expires_on"/>
                <field name="source_url"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_knowledge_article_form" model="ir.ui.view">
        <field name="name">omni.knowledge.article.form</field>
        <field name="model">omni.knowledge.article</field>
        <field name="arch" type="xml">
            <form string="Knowledge Article">
                <sheet>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="priority"/>
                            <field name="category"/>
                            <field name="channel_scope"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="source_url"/>
                            <field name="source_type"/>
                            <field name="source_ref"/>
                            <field name="source_timestamp"/>
                            <field name="editorial_approved"/>
                            <field name="fact_expires_on"/>
                        </group>
                    </group>
                    <group>
                        <field name="body"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_knowledge_article" model="ir.actions.act_window">
        <field name="name">Knowledge Articles</field>
        <field name="res_model">omni.knowledge.article</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

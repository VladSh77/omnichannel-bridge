<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_stage_transition_tree" model="ir.ui.view">
        <field name="name">omni.stage.transition.tree</field>
        <field name="model">omni.stage.transition</field>
        <field name="arch" type="xml">
            <tree>
                <field name="active"/>
                <field name="from_stage"/>
                <field name="to_stage"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_stage_transition_form" model="ir.ui.view">
        <field name="name">omni.stage.transition.form</field>
        <field name="model">omni.stage.transition</field>
        <field name="arch" type="xml">
            <form string="Stage Transition">
                <sheet>
                    <group>
                        <field name="active"/>
                        <field name="from_stage"/>
                        <field name="to_stage"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_stage_transition" model="ir.actions.act_window">
        <field name="name">Stage Transitions</field>
        <field name="res_model">omni.stage.transition</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

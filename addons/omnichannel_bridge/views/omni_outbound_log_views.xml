<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_outbound_log_tree" model="ir.ui.view">
        <field name="name">omni.outbound.log.tree</field>
        <field name="model">omni.outbound.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="created_at"/>
                <field name="provider"/>
                <field name="external_thread_id"/>
                <field name="ok"/>
                <field name="status_code"/>
                <field name="endpoint"/>
                <field name="error_snippet"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_outbound_log_form" model="ir.ui.view">
        <field name="name">omni.outbound.log.form</field>
        <field name="model">omni.outbound.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="created_at"/>
                        <field name="provider"/>
                        <field name="external_thread_id"/>
                        <field name="event_type"/>
                        <field name="ok"/>
                        <field name="status_code"/>
                    </group>
                    <group>
                        <field name="endpoint"/>
                        <field name="error_snippet"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_outbound_log" model="ir.actions.act_window">
        <field name="name">Outbound Delivery Log</field>
        <field name="res_model">omni.outbound.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

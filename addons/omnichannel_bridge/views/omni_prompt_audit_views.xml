<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_prompt_audit_tree" model="ir.ui.view">
        <field name="name">omni.prompt.audit.tree</field>
        <field name="model">omni.prompt.audit</field>
        <field name="arch" type="xml">
            <tree create="false" delete="false">
                <field name="changed_at"/>
                <field name="changed_by"/>
                <field name="key_name"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_prompt_audit_form" model="ir.ui.view">
        <field name="name">omni.prompt.audit.form</field>
        <field name="model">omni.prompt.audit</field>
        <field name="arch" type="xml">
            <form create="false" delete="false">
                <sheet>
                    <group>
                        <field name="changed_at"/>
                        <field name="changed_by"/>
                        <field name="key_name"/>
                        <field name="note"/>
                    </group>
                    <group>
                        <field name="old_value"/>
                        <field name="new_value"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_prompt_audit" model="ir.actions.act_window">
        <field name="name">Prompt Audit</field>
        <field name="res_model">omni.prompt.audit</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

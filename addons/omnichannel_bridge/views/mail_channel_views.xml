<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mail_channel_view_form_inherit_omnichannel" model="ir.ui.view">
        <field name="name">mail.channel.form.inherit.omnichannel</field>
        <field name="model">mail.channel</field>
        <field name="inherit_id" ref="mail.mail_channel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Omnichannel" name="omnichannel_group" groups="base.group_user">
                    <field name="omni_provider" readonly="1"/>
                    <field name="omni_external_thread_id" readonly="1"/>
                    <field name="omni_customer_partner_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_inbox_thread_tree" model="ir.ui.view">
        <field name="name">omni.inbox.thread.tree</field>
        <field name="model">omni.inbox.thread</field>
        <field name="arch" type="xml">
            <tree string="Інбокс оператора" create="false" delete="false" multi_edit="0">
                <header>
                    <button name="action_sync_all_from_threads" type="object" string="Оновити з Discuss"
                            class="btn-secondary" groups="sales_team.group_sale_manager" display="always"/>
                </header>
                <field name="thread_name"/>
                <field name="provider"/>
                <field name="partner_id"/>
                <field name="last_message_preview"/>
                <field name="last_message_at"/>
                <field name="operator_status"/>
                <field name="needaction_counter"/>
                <button name="action_open_in_discuss" type="object" string="Discuss" class="btn-link"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_inbox_thread_search" model="ir.ui.view">
        <field name="name">omni.inbox.thread.search</field>
        <field name="model">omni.inbox.thread</field>
        <field name="arch" type="xml">
            <search string="Інбокс">
                <field name="thread_name"/>
                <field name="provider"/>
                <field name="partner_id"/>
                <field name="external_thread_id"/>
                <filter string="Потребує уваги" name="needaction" domain="[('needaction_counter', '&gt;', 0)]"/>
                <filter string="Клієнт очікує" name="client_waiting" domain="[('operator_status', '=', 'client_waiting')]"/>
                <filter string="Менеджер у діалозі" name="manager" domain="[('operator_status', '=', 'manager')]"/>
                <group expand="0" string="Групувати за">
                    <filter string="Канал" name="grp_provider" context="{'group_by': 'provider'}"/>
                    <filter string="Статус" name="grp_status" context="{'group_by': 'operator_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_omni_inbox_thread_form" model="ir.ui.view">
        <field name="name">omni.inbox.thread.form</field>
        <field name="model">omni.inbox.thread</field>
        <field name="arch" type="xml">
            <form string="Рядок інбоксу" create="false" edit="false" delete="false">
                <header>
                    <button name="action_open_in_discuss" type="object" string="Відкрити в Discuss" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="thread_name"/>
                        <field name="provider"/>
                        <field name="partner_id"/>
                        <field name="external_thread_id"/>
                        <field name="last_message_preview"/>
                        <field name="last_message_at"/>
                        <field name="operator_status"/>
                        <field name="needaction_counter"/>
                        <field name="channel_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_inbox_thread" model="ir.actions.act_window">
        <field name="name">Інбокс оператора</field>
        <field name="res_model">omni.inbox.thread</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Ще немає рядків. Вони з’являться після повідомлень у месенджерних тредах або після кнопки «Оновити з Discuss» (менеджер продажів).
            </p>
        </field>
    </record>

    <!-- Картка розмови (з Discuss): редагування прив'язки клієнта, ідентифікація без дублів -->
    <record id="view_omni_inbox_thread_form_conversation" model="ir.ui.view">
        <field name="name">omni.inbox.thread.form.conversation</field>
        <field name="model">omni.inbox.thread</field>
        <field name="priority">32</field>
        <field name="arch" type="xml">
            <form string="Картка розмови" create="false" delete="false">
                <header>
                    <button name="action_open_in_discuss" type="object"
                            string="Відкрити чат" class="btn-primary"
                            invisible="conversation_stage == 'close'"/>
                    <button name="action_refresh_profile" type="object"
                            string="Оновити профіль" class="btn-secondary"/>
                    <button name="action_close_conversation" type="object"
                            string="Закрити розмову" class="btn-secondary"
                            invisible="conversation_stage == 'close'"/>
                    <button name="action_reopen_conversation" type="object"
                            string="Відновити" class="btn-secondary"
                            invisible="conversation_stage != 'close'"/>
                    <button name="action_open_identify_wizard" type="object"
                            string="Ідентифікувати клієнта" class="btn-warning"
                            invisible="partner_id != False or conversation_stage == 'close'"/>
                    <field name="conversation_stage" widget="statusbar"
                           statusbar_visible="new,in_progress,new_message,close"/>
                </header>
                <sheet>
                    <group>
                        <group string="Клієнт">
                            <field name="partner_id"
                                   options="{'no_create': True, 'no_create_edit': True}"
                                   placeholder="Не ідентифікований"/>
                            <button name="action_open_partner_form" type="object"
                                    string="Відкрити картку клієнта" class="btn-link"
                                    invisible="not partner_id"/>
                            <field name="partner_email" readonly="1" invisible="partner_id == False"/>
                            <field name="partner_phone" readonly="1" invisible="partner_id == False"/>
                        </group>
                        <group string="Канал">
                            <field name="provider" readonly="1"/>
                            <field name="social_username" readonly="1"/>
                            <field name="social_profile_url" readonly="1" widget="url"/>
                            <field name="bot_name" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Дані бота">
                            <field name="sp_child_name"/>
                            <field name="sp_booking_email"/>
                        </group>
                        <group string="ПРОФІЛЬ SENDPULSE">
                            <field name="language_code" string="Мова"/>
                            <field name="subscription_status_label" readonly="1" string="Статус підписки"/>
                        </group>
                    </group>
                    <group>
                        <group string="Оператори">
                            <field name="operator_user_ids" widget="many2many_tags"
                                   options="{'no_create': True, 'no_create_edit': True}"
                                   domain="[('share', '=', False), ('active', '=', True)]"/>
                            <field name="operator_status" readonly="1"/>
                        </group>
                        <group string="SENDPULSE">
                            <field name="external_thread_id" readonly="1" string="Contact ID"/>
                            <field name="last_message_at" readonly="1" string="Останнє повідомлення"/>
                            <field name="thread_name" readonly="1" string="Discuss Канал"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Повідомлення" name="messages">
                            <field name="message_ids" readonly="1">
                                <tree create="false" delete="false">
                                    <field name="date" string="Дата"/>
                                    <field name="author_id" string="Напрямок"/>
                                    <field name="body" string="Текст"/>
                                    <field name="attachment_ids" string="Вкладення"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <field name="channel_id" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_promo_tree" model="ir.ui.view">
        <field name="name">omni.promo.tree</field>
        <field name="model">omni.promo</field>
        <field name="arch" type="xml">
            <tree>
                <field name="active"/>
                <field name="name"/>
                <field name="code"/>
                <field name="discount_percent"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="channel_scope"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_promo_form" model="ir.ui.view">
        <field name="name">omni.promo.form</field>
        <field name="model">omni.promo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="active"/>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="discount_percent"/>
                        <field name="channel_scope"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </group>
                    <group string="Scope and terms">
                        <field name="product_tmpl_ids" widget="many2many_tags"/>
                        <field name="terms"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_promo" model="ir.actions.act_window">
        <field name="name">Promotions</field>
        <field name="res_model">omni.promo</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_reserve_entry_tree" model="ir.ui.view">
        <field name="name">omni.reserve.entry.tree</field>
        <field name="model">omni.reserve.entry</field>
        <field name="arch" type="xml">
            <tree>
                <field name="requested_at"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="provider"/>
                <field name="channel_id"/>
                <field name="lead_id"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_reserve_entry_form" model="ir.ui.view">
        <field name="name">omni.reserve.entry.form</field>
        <field name="model">omni.reserve.entry</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="active"/>
                        <field name="requested_at" readonly="1"/>
                        <field name="state"/>
                        <field name="partner_id"/>
                        <field name="provider"/>
                        <field name="channel_id"/>
                        <field name="lead_id"/>
                    </group>
                    <group>
                        <field name="user_text"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_reserve_entry" model="ir.actions.act_window">
        <field name="name">Reserve Waitlist</field>
        <field name="res_model">omni.reserve.entry</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_legal_document_tree" model="ir.ui.view">
        <field name="name">omni.legal.document.tree</field>
        <field name="model">omni.legal.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="active" string="Активний"/>
                <field name="name" string="Назва"/>
                <field name="doc_type" string="Тип"/>
                <field name="version_tag" string="Версія"/>
                <field name="effective_from" string="Діє з"/>
                <field name="is_pdf" string="PDF"/>
                <field name="allow_in_bot" string="У боті"/>
                <field name="url" string="URL"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_legal_document_form" model="ir.ui.view">
        <field name="name">omni.legal.document.form</field>
        <field name="model">omni.legal.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="active"/>
                        <field name="name"/>
                        <field name="doc_type"/>
                        <field name="version_tag"/>
                        <field name="effective_from"/>
                        <field name="url"/>
                        <field name="is_pdf"/>
                        <field name="allow_in_bot"/>
                        <field name="approved_by"/>
                        <field name="approved_at"/>
                    </group>
                    <group string="Коротка дозволена цитата">
                        <field name="short_quote"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_legal_document" model="ir.actions.act_window">
        <field name="name">Юридичні документи</field>
        <field name="res_model">omni.legal.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_omni_legal_document"
        name="Юридичні документи"
        parent="menu_omni_root"
        action="action_omni_legal_document"
        sequence="26"
    />
</odoo>

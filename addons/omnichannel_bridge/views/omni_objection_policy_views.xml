<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_objection_policy_tree" model="ir.ui.view">
        <field name="name">omni.objection.policy.tree</field>
        <field name="model">omni.objection.policy</field>
        <field name="arch" type="xml">
            <tree>
                <field name="active" string="Активний"/>
                <field name="objection_type" string="Тип заперечення"/>
                <field name="channel_scope" string="Канал"/>
                <field name="body" string="Текст"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_objection_policy_form" model="ir.ui.view">
        <field name="name">omni.objection.policy.form</field>
        <field name="model">omni.objection.policy</field>
        <field name="arch" type="xml">
            <form string="Політика заперечень">
                <sheet>
                    <group>
                        <field name="active"/>
                        <field name="objection_type"/>
                        <field name="channel_scope"/>
                    </group>
                    <group>
                        <field name="body"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_objection_policy" model="ir.actions.act_window">
        <field name="name">Політики заперечень</field>
        <field name="res_model">omni.objection.policy</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Тут задаються тексти відповіді на типові заперечення для ШІ.
            </p>
            <p>
                Після оновлення модуля з’являються стартові рядки (за замовчуванням з коду).
                Один активний рядок на <strong>тип заперечення</strong> перекриває шаблон з налаштувань.
            </p>
        </field>
    </record>
</odoo>

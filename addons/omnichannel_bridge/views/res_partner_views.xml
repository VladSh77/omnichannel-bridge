<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_omnichannel" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.omnichannel</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Omnichannel" name="omnichannel_page" groups="sales_team.group_sale_salesman">
                    <group>
                        <button name="action_omni_right_to_erasure" type="object" string="Right to Erasure (Anonymize)"
                                class="btn-secondary"/>
                        <field name="omni_erased_at" readonly="1"/>
                    </group>
                    <group string="Звертання для бота">
                        <field name="omni_addressing_style"/>
                        <field name="omni_addressing_vocative" placeholder="Наприклад: Ольго"/>
                    </group>
                    <group string="Пам’ять з діалогів">
                        <field name="omni_chat_memory" colspan="2" nolabel="1"/>
                    </group>
                    <group string="Профіль підбору табору">
                        <field name="omni_child_age"/>
                        <field name="omni_preferred_period"/>
                        <field name="omni_departure_city"/>
                        <field name="omni_budget_amount"/>
                        <field name="omni_budget_currency"/>
                        <field name="omni_sales_stage"/>
                    </group>
                    <field name="omni_identity_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="provider"/>
                            <field name="external_id"/>
                            <field name="display_name"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_omni_crm_analytics_wizard_line_tree" model="ir.ui.view">
        <field name="name">omni.crm.analytics.wizard.line.tree</field>
        <field name="model">omni.crm.analytics.wizard.line</field>
        <field name="arch" type="xml">
            <tree string="Analytics Breakdown" create="false" delete="false">
                <field name="section"/>
                <field name="label"/>
                <field name="count"/>
            </tree>
        </field>
    </record>

    <record id="view_omni_crm_analytics_wizard_form" model="ir.ui.view">
        <field name="name">omni.crm.analytics.wizard.form</field>
        <field name="model">omni.crm.analytics.wizard</field>
        <field name="arch" type="xml">
            <form string="CRM Analytics" create="true" edit="true">
                <header>
                    <button name="action_refresh" type="object" string="Refresh metrics" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group string="Key Metrics">
                        <group>
                            <field name="total_threads" readonly="1"/>
                            <field name="total_leads" readonly="1"/>
                            <field name="handoff_threads" readonly="1"/>
                            <field name="tg_new_contacts" readonly="1"/>
                        </group>
                        <group>
                            <field name="avg_response_seconds" readonly="1"/>
                            <field name="objection_events" readonly="1"/>
                            <field name="purchase_intent_events" readonly="1"/>
                            <field name="objection_to_intent_percent" readonly="1"/>
                            <field name="coupon_redemptions_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Reply Ownership">
                        <group>
                            <field name="bot_reply_threads" readonly="1"/>
                            <field name="human_reply_threads" readonly="1"/>
                            <field name="mixed_reply_threads" readonly="1"/>
                        </group>
                    </group>
                    <group string="Campaign / ROMI">
                        <group>
                            <field name="coupon_discount_total" readonly="1"/>
                            <field name="coupon_orders_revenue" readonly="1"/>
                            <field name="meta_leads_fact" readonly="1"/>
                            <field name="meta_purchases_fact" readonly="1"/>
                        </group>
                        <group>
                            <field name="ad_spend_amount"/>
                            <field name="romi_percent" readonly="1"/>
                            <field name="meta_goal_leads"/>
                            <field name="meta_goal_leads_achievement_percent" readonly="1"/>
                            <field name="meta_goal_purchases"/>
                            <field name="meta_goal_purchases_achievement_percent" readonly="1"/>
                        </group>
                    </group>
                    <group string="Breakdown">
                        <field name="line_ids" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_omni_crm_analytics_wizard" model="ir.actions.act_window">
        <field name="name">CRM Analytics</field>
        <field name="res_model">omni.crm.analytics.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>
</odoo>

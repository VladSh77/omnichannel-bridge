<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_omnichannel" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.omnichannel</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Omnichannel" name="omnichannel_bridge_settings" groups="base.group_system">
                    <block title="Meta (Facebook / Instagram)" name="omnichannel_block_meta">
                        <setting string="Webhook verify token" help="Same value as hub.verify_token in Meta webhook subscription (GET challenge).">
                            <field name="omnichannel_meta_verify_token" password="True"/>
                        </setting>
                        <setting string="Page access token (fallback)" help="Prefer Omnichannel → Integrations (Meta).">
                            <field name="omnichannel_meta_page_access_token" password="True"/>
                        </setting>
                        <setting string="App secret" help="Used to validate X-Hub-Signature-256 on POST webhooks.">
                            <field name="omnichannel_meta_app_secret" password="True"/>
                        </setting>
                        <setting string="WhatsApp verify token" help="Token for /omni/webhook/whatsapp GET verification. Falls back to Meta token if empty.">
                            <field name="omnichannel_whatsapp_verify_token" password="True"/>
                        </setting>
                        <setting string="WhatsApp phone number ID" help="Cloud API sender phone_number_id used for outbound replies.">
                            <field name="omnichannel_whatsapp_phone_number_id"/>
                        </setting>
                        <setting string="WhatsApp app secret" help="Used to validate X-Hub-Signature-256 for WhatsApp webhooks. Falls back to Meta app secret if empty.">
                            <field name="omnichannel_whatsapp_app_secret" password="True"/>
                        </setting>
                        <setting string="Viber bot token (fallback)" help="Prefer Omnichannel → Integrations (Viber). Used for outbound send_message.">
                            <field name="omnichannel_viber_bot_token" password="True"/>
                        </setting>
                        <setting string="Viber webhook secret" help="Optional HMAC SHA256 validation of X-Viber-Content-Signature.">
                            <field name="omnichannel_viber_webhook_secret" password="True"/>
                        </setting>
                    </block>
                    <block title="Bot schedule" name="omnichannel_block_schedule">
                        <setting help="Use company timezone (on the main company contact).">
                            <field name="omnichannel_bot_reply_mode"/>
                        </setting>
                        <setting string="SLA wait before bot reply (sec)" help="Typical value: 180 seconds. If manager replies before timeout, queued bot reply is cancelled.">
                            <field name="omnichannel_sla_no_human_seconds"/>
                        </setting>
                        <setting string="SLA scope">
                            <field name="omnichannel_sla_scope"/>
                        </setting>
                        <setting string="Manager session lock timeout (minutes)" help="After manager message, bot remains paused in messenger threads for this duration.">
                            <field name="omnichannel_manager_session_timeout_minutes"/>
                        </setting>
                        <setting string="Outbound conflict guard (seconds)" help="Suppress bot reply right after manager message and deduplicate repeated outbound text in the same short window.">
                            <field name="omnichannel_outbound_conflict_guard_seconds"/>
                        </setting>
                        <setting string="Manager hours start">
                            <field name="omnichannel_manager_hour_start"/>
                        </setting>
                        <setting string="Manager hours end">
                            <field name="omnichannel_manager_hour_end"/>
                        </setting>
                        <setting string="Bot after quiet (during manager hours)" help="Waits SLA seconds before running the AI job so the manager can answer first (Meta/Telegram only).">
                            <field name="omnichannel_bot_inside_hours_if_manager_quiet"/>
                        </setting>
                        <setting string="Night window (optional)" help="If enabled, bot may always reply in this local window (company timezone).">
                            <field name="omnichannel_night_bot_enabled"/>
                        </setting>
                        <setting string="Night start" invisible="not omnichannel_night_bot_enabled">
                            <field name="omnichannel_night_bot_start"/>
                        </setting>
                        <setting string="Night end" invisible="not omnichannel_night_bot_enabled">
                            <field name="omnichannel_night_bot_end"/>
                        </setting>
                        <setting string="Max webhook body (bytes)" help="Reject oversized webhook POST payloads.">
                            <field name="omnichannel_webhook_max_body_bytes"/>
                        </setting>
                        <setting string="Webhook per-IP rate limit (req/min)">
                            <field name="omnichannel_webhook_rate_limit_per_minute"/>
                        </setting>
                        <setting string="Enable 24h window reminder automation" help="For Meta/WhatsApp-like channels: send one soft reminder around the configured hour in active message window.">
                            <field name="omnichannel_window_reminder_enabled"/>
                        </setting>
                        <setting string="Reminder trigger (hours)" invisible="not omnichannel_window_reminder_enabled">
                            <field name="omnichannel_window_reminder_trigger_hours"/>
                        </setting>
                        <setting string="Window max (hours)" invisible="not omnichannel_window_reminder_enabled">
                            <field name="omnichannel_window_message_window_hours"/>
                        </setting>
                        <setting string="Last-call before close (hours)" invisible="not omnichannel_window_reminder_enabled">
                            <field name="omnichannel_window_last_call_hours_before_close"/>
                        </setting>
                        <setting string="Reminder text" invisible="not omnichannel_window_reminder_enabled">
                            <field name="omnichannel_window_reminder_text" placeholder="Підкажіть, будь ласка, чи встигли обрати програму табору?..."/>
                        </setting>
                        <setting string="Last-call text" invisible="not omnichannel_window_reminder_enabled">
                            <field name="omnichannel_window_last_call_text" placeholder="Вікно повідомлень скоро закриється — якщо зручно, залиште короткий апдейт і я підключу менеджера."/>
                        </setting>
                        <setting string="Cooldown reminder (minutes)">
                            <field name="omnichannel_cooldown_reminder_minutes"/>
                        </setting>
                        <setting string="Cooldown FOMO (minutes)">
                            <field name="omnichannel_cooldown_fomo_minutes"/>
                        </setting>
                        <setting string="Cooldown last-call (minutes)">
                            <field name="omnichannel_cooldown_last_call_minutes"/>
                        </setting>
                        <setting string="Global cooldown (minutes)">
                            <field name="omnichannel_cooldown_global_minutes"/>
                        </setting>
                        <setting string="Retention: omni chat messages (days)">
                            <field name="omnichannel_retention_message_days"/>
                        </setting>
                        <setting string="Retention: webhook events (days)">
                            <field name="omnichannel_retention_webhook_days"/>
                        </setting>
                        <setting string="Retention: child-sensitive fields (days)">
                            <field name="omnichannel_retention_child_data_days"/>
                        </setting>
                        <setting string="Mask PII in bridge logs">
                            <field name="omnichannel_log_pii_masking"/>
                        </setting>
                    </block>
                    <block title="CRM" name="omnichannel_block_crm">
                        <setting help="Creates a CRM lead when a brand-new messenger identity appears.">
                            <field name="omnichannel_new_contact_as_lead"/>
                        </setting>
                    </block>
                    <block title="Telegram" name="omnichannel_block_telegram">
                        <setting string="Bot token (fallback)" help="Prefer Omnichannel → Integrations per company.">
                            <field name="omnichannel_telegram_bot_token" password="True"/>
                        </setting>
                        <setting string="Webhook secret" help="Must match Telegram secret_token when registering the webhook.">
                            <field name="omnichannel_telegram_webhook_secret" password="True"/>
                        </setting>
                        <setting string="Public coupon channel URL" help="Clients should open this public channel to copy current -5% code.">
                            <field name="omnichannel_coupon_public_channel_url"/>
                        </setting>
                        <setting string="Public coupon code" help="Current promo code published in Telegram channel.">
                            <field name="omnichannel_coupon_public_code"/>
                        </setting>
                        <setting string="Coupon discount (%)" help="Applied only to camp lines on sale order.">
                            <field name="omnichannel_coupon_discount_percent"/>
                        </setting>
                        <setting string="Coupon allowed camp categories" help="Optional hard limit: coupon applies only to camp products in selected categories/subcategories.">
                            <field name="omnichannel_coupon_allowed_categ_ids" widget="many2many_tags"/>
                        </setting>
                    </block>
                    <block title="Internal notifications" name="omnichannel_block_internal_notify">
                        <setting string="Internal Telegram bot token">
                            <field name="omnichannel_internal_tg_bot_token" password="True"/>
                        </setting>
                        <setting string="Internal Telegram chat ID">
                            <field name="omnichannel_internal_tg_chat_id"/>
                        </setting>
                        <setting string="Priority chat ID (optional)" help="If filled, urgent/problematic notifications are duplicated to this channel for faster attention.">
                            <field name="omnichannel_internal_tg_priority_chat_id"/>
                        </setting>
                        <setting string="Internal Telegram API base">
                            <field name="omnichannel_internal_tg_api_base"/>
                        </setting>
                        <setting string="Allowed internal Telegram user IDs">
                            <field name="omnichannel_internal_tg_allowed_user_ids"/>
                        </setting>
                        <setting string="Notify on new thread">
                            <field name="omnichannel_internal_notify_new"/>
                        </setting>
                        <setting string="Notify on escalation">
                            <field name="omnichannel_internal_notify_escalate"/>
                        </setting>
                        <setting string="Notify on problematic flag">
                            <field name="omnichannel_internal_notify_problem"/>
                        </setting>
                        <setting string="Priority keywords override">
                            <field name="omnichannel_internal_notify_priority_keywords"/>
                        </setting>
                        <setting string="Default manager user" help="Used as handoff owner for direct assignment and activities on priority events.">
                            <field name="omnichannel_default_manager_user_id"/>
                        </setting>
                        <setting string="Send manager email on priority events">
                            <field name="omnichannel_internal_notify_email_manager"/>
                        </setting>
                        <setting string="Purchase dedup window (minutes)">
                            <field name="omnichannel_purchase_dedup_minutes"/>
                        </setting>
                    </block>
                    <block title="LLM (факти з Odoo, без вигадок)" name="omnichannel_block_llm">
                        <setting string="Увімкнути автовідповіді" help="Рекомендовано: Ollama (локально, відкриті ваги). OpenAI — опційно, пропрієтарний хмарний API.">
                            <field name="omnichannel_llm_enabled"/>
                        </setting>
                        <setting string="AI у чаті сайту (Odoo Live Chat)" help="Якщо вимкнено, бот не відповідає у live chat на сайті, навіть коли LLM загалом увімкнений.">
                            <field name="omnichannel_site_livechat_enabled"/>
                        </setting>
                        <setting string="Бекенд">
                            <field name="omnichannel_llm_backend"/>
                        </setting>
                        <setting string="Суворе підґрунтя" help="Модель отримує лише FACTS_FROM_DATABASE з Python/Odoo; інструкція забороняє вигадувати ціни та місця.">
                            <field name="omnichannel_llm_strict_grounding"/>
                        </setting>
                        <setting string="Контекст: останні повідомлення треду" help="Марковано як не фінансова правда; для зв’язності діалогу.">
                            <field name="omnichannel_llm_include_transcript"/>
                        </setting>
                        <setting string="Скільки останніх повідомлень">
                            <field name="omnichannel_llm_transcript_messages"/>
                        </setting>
                        <setting string="Debug джерел фактів" help="Додає технічний блок DATA_SOURCES_DEBUG у контекст LLM (для внутрішньої валідації).">
                            <field name="omnichannel_llm_debug_data_sources"/>
                        </setting>
                        <setting string="Ollama URL">
                            <field name="omnichannel_ollama_base_url"/>
                        </setting>
                        <setting string="Ollama model">
                            <field name="omnichannel_ollama_model"/>
                        </setting>
                        <setting string="OpenAI API key" help="Лише якщо бекенд = OpenAI.">
                            <field name="omnichannel_openai_api_key" password="True"/>
                        </setting>
                        <setting string="OpenAI model">
                            <field name="omnichannel_openai_model"/>
                        </setting>
                        <setting string="Legacy OpenAI toggle" help="Якщо увімкнено без llm_enabled — LLM вважається увімкненим (зворотна сумісність).">
                            <field name="omnichannel_openai_enabled"/>
                        </setting>
                        <setting string="Базовий системний промпт">
                            <field name="omnichannel_openai_system_prompt" placeholder="Тон, емпатія, сценарій продажу — без вигаданих цифр (їх дає блок фактів)."/>
                        </setting>
                        <setting string="Prompt version tag">
                            <field name="omnichannel_llm_prompt_version"/>
                        </setting>
                        <setting string="Prompt experiment tag (A/B)">
                            <field name="omnichannel_llm_experiment_tag"/>
                        </setting>
                        <setting string="Assistant profile">
                            <field name="omnichannel_llm_assistant_profile"/>
                        </setting>
                        <setting string="Moderation keywords">
                            <field name="omnichannel_moderation_keywords"/>
                        </setting>
                        <setting string="Moderation action">
                            <field name="omnichannel_moderation_action"/>
                        </setting>
                        <setting string="Vocative map extra">
                            <field name="omnichannel_vocative_map_extra" placeholder="олена:Олено, віра:Віро, павел:Pawle"/>
                        </setting>
                    </block>
                    <block title="Legal Pack (approved snippets)" name="omnichannel_block_legal_pack">
                        <setting string="Terms URL">
                            <field name="omnichannel_legal_terms_url"/>
                        </setting>
                        <setting string="Privacy URL">
                            <field name="omnichannel_legal_privacy_url"/>
                        </setting>
                        <setting string="Cookie URL">
                            <field name="omnichannel_legal_cookie_url"/>
                        </setting>
                        <setting string="Child protection URL">
                            <field name="omnichannel_legal_child_protection_url"/>
                        </setting>
                        <setting string="Approved short offer wording">
                            <field name="omnichannel_legal_short_offer_text" placeholder="Коротке узгоджене формулювання для оферти."/>
                        </setting>
                        <setting string="Approved short RODO wording">
                            <field name="omnichannel_legal_short_rodo_text" placeholder="Коротке узгоджене формулювання по обробці даних."/>
                        </setting>
                        <setting string="Approved short child-data wording">
                            <field name="omnichannel_legal_short_child_text" placeholder="Коротке узгоджене формулювання щодо мінімізації даних дітей."/>
                        </setting>
                        <setting string="Legal approvals owner">
                            <field name="omnichannel_legal_approved_owner"/>
                        </setting>
                        <setting string="Consent text for Meta/Instagram">
                            <field name="omnichannel_consent_meta_text"/>
                        </setting>
                        <setting string="Consent text for Telegram">
                            <field name="omnichannel_consent_telegram_text"/>
                        </setting>
                        <setting string="Consent text for WhatsApp">
                            <field name="omnichannel_consent_whatsapp_text"/>
                        </setting>
                        <setting string="Consent text for website livechat">
                            <field name="omnichannel_consent_site_text"/>
                        </setting>
                    </block>
                    <block title="Release &amp; Token Rotation" name="omnichannel_block_release_token">
                        <setting string="Release Odoo version">
                            <field name="omnichannel_release_odoo_version"/>
                        </setting>
                        <setting string="Release custom repo hash">
                            <field name="omnichannel_release_custom_hash"/>
                        </setting>
                        <setting string="Release Ollama model version">
                            <field name="omnichannel_release_ollama_model_version"/>
                        </setting>
                        <setting string="Token rotation owner">
                            <field name="omnichannel_token_rotation_owner"/>
                        </setting>
                        <setting string="Token rotation next date">
                            <field name="omnichannel_token_rotation_next_date"/>
                        </setting>
                    </block>
                    <block title="Sales objections playbook" name="omnichannel_block_objections">
                        <setting string="Price objection">
                            <field name="omnichannel_objection_playbook_price" placeholder="Empathize, use ORM facts only, ask one budget-calibration question."/>
                        </setting>
                        <setting string="Timing objection">
                            <field name="omnichannel_objection_playbook_timing" placeholder="Respect timing, suggest low-friction next step, no pressure."/>
                        </setting>
                        <setting string="Trust objection">
                            <field name="omnichannel_objection_playbook_trust" placeholder="Use only verifiable links/facts, offer manager handoff."/>
                        </setting>
                        <setting string="Need to think">
                            <field name="omnichannel_objection_playbook_need_to_think" placeholder="Clarify blocker and answer one concrete concern with facts."/>
                        </setting>
                        <setting string="Competitor objection">
                            <field name="omnichannel_objection_playbook_competitor" placeholder="Do not attack competitors; compare only own offer from ORM/legal links."/>
                        </setting>
                        <setting string="Not decision maker">
                            <field name="omnichannel_objection_playbook_not_decision_maker" placeholder="Ask who decides and suggest a convenient handoff/call slot."/>
                        </setting>
                        <setting string="Pain discovery script">
                            <field name="omnichannel_pain_script" placeholder="Short script to discover blockers and pains in consultative style."/>
                        </setting>
                        <setting string="Upsell script">
                            <field name="omnichannel_upsell_script" placeholder="Short script with non-aggressive upsell/cross-sell hints based on ORM facts."/>
                        </setting>
                        <setting string="Warm style policy">
                            <field name="omnichannel_style_warm_policy" placeholder="Warm, respectful, premium tone; no pressure or aggressive urgency."/>
                        </setting>
                        <setting string="FOMO manager internal notify">
                            <field name="omnichannel_fomo_internal_notify"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>

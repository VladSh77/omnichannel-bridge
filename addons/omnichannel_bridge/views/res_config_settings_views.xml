<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_omnichannel" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.omnichannel</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Omnichannel" name="omnichannel_bridge_settings" groups="base.group_system">
                    <block title="Meta (Facebook / Instagram)" name="omnichannel_block_meta">
                        <setting string="Webhook verify token" help="Same value as hub.verify_token in Meta webhook subscription (GET challenge).">
                            <field name="omnichannel_meta_verify_token" password="True"/>
                        </setting>
                        <setting string="Page access token (fallback)" help="Prefer Omnichannel → Integrations (Meta).">
                            <field name="omnichannel_meta_page_access_token" password="True"/>
                        </setting>
                        <setting string="App secret" help="Used to validate X-Hub-Signature-256 on POST webhooks.">
                            <field name="omnichannel_meta_app_secret" password="True"/>
                        </setting>
                    </block>
                    <block title="Bot schedule" name="omnichannel_block_schedule">
                        <setting help="Use company timezone (on the main company contact).">
                            <field name="omnichannel_bot_reply_mode"/>
                        </setting>
                        <setting string="SLA wait before bot reply (sec)" help="Typical value: 180 seconds. If manager replies before timeout, queued bot reply is cancelled.">
                            <field name="omnichannel_sla_no_human_seconds"/>
                        </setting>
                        <setting string="Manager hours start">
                            <field name="omnichannel_manager_hour_start"/>
                        </setting>
                        <setting string="Manager hours end">
                            <field name="omnichannel_manager_hour_end"/>
                        </setting>
                        <setting string="Bot after quiet (during manager hours)" help="Waits SLA seconds before running the AI job so the manager can answer first (Meta/Telegram only).">
                            <field name="omnichannel_bot_inside_hours_if_manager_quiet"/>
                        </setting>
                        <setting string="Night window (optional)" help="If enabled, bot may always reply in this local window (company timezone).">
                            <field name="omnichannel_night_bot_enabled"/>
                        </setting>
                        <setting string="Night start" invisible="not omnichannel_night_bot_enabled">
                            <field name="omnichannel_night_bot_start"/>
                        </setting>
                        <setting string="Night end" invisible="not omnichannel_night_bot_enabled">
                            <field name="omnichannel_night_bot_end"/>
                        </setting>
                        <setting string="Max webhook body (bytes)" help="Reject oversized webhook POST payloads.">
                            <field name="omnichannel_webhook_max_body_bytes"/>
                        </setting>
                        <setting string="Enable 24h window reminder automation" help="For Meta/WhatsApp-like channels: send one soft reminder around the configured hour in active message window.">
                            <field name="omnichannel_window_reminder_enabled"/>
                        </setting>
                        <setting string="Reminder trigger (hours)" invisible="not omnichannel_window_reminder_enabled">
                            <field name="omnichannel_window_reminder_trigger_hours"/>
                        </setting>
                        <setting string="Window max (hours)" invisible="not omnichannel_window_reminder_enabled">
                            <field name="omnichannel_window_message_window_hours"/>
                        </setting>
                        <setting string="Reminder text" invisible="not omnichannel_window_reminder_enabled">
                            <field name="omnichannel_window_reminder_text" placeholder="Підкажіть, будь ласка, чи встигли обрати програму табору?..."/>
                        </setting>
                    </block>
                    <block title="CRM" name="omnichannel_block_crm">
                        <setting help="Creates a CRM lead when a brand-new messenger identity appears.">
                            <field name="omnichannel_new_contact_as_lead"/>
                        </setting>
                    </block>
                    <block title="Telegram" name="omnichannel_block_telegram">
                        <setting string="Bot token (fallback)" help="Prefer Omnichannel → Integrations per company.">
                            <field name="omnichannel_telegram_bot_token" password="True"/>
                        </setting>
                        <setting string="Webhook secret" help="Must match Telegram secret_token when registering the webhook.">
                            <field name="omnichannel_telegram_webhook_secret" password="True"/>
                        </setting>
                        <setting string="Public coupon channel URL" help="Clients should open this public channel to copy current -5% code.">
                            <field name="omnichannel_coupon_public_channel_url"/>
                        </setting>
                    </block>
                    <block title="Internal notifications" name="omnichannel_block_internal_notify">
                        <setting string="Internal Telegram bot token">
                            <field name="omnichannel_internal_tg_bot_token" password="True"/>
                        </setting>
                        <setting string="Internal Telegram chat ID">
                            <field name="omnichannel_internal_tg_chat_id"/>
                        </setting>
                        <setting string="Priority chat ID (optional)" help="If filled, urgent/problematic notifications are duplicated to this channel for faster attention.">
                            <field name="omnichannel_internal_tg_priority_chat_id"/>
                        </setting>
                        <setting string="Notify on new thread">
                            <field name="omnichannel_internal_notify_new"/>
                        </setting>
                        <setting string="Notify on escalation">
                            <field name="omnichannel_internal_notify_escalate"/>
                        </setting>
                        <setting string="Notify on problematic flag">
                            <field name="omnichannel_internal_notify_problem"/>
                        </setting>
                    </block>
                    <block title="LLM (факти з Odoo, без вигадок)" name="omnichannel_block_llm">
                        <setting string="Увімкнути автовідповіді" help="Рекомендовано: Ollama (локально, відкриті ваги). OpenAI — опційно, пропрієтарний хмарний API.">
                            <field name="omnichannel_llm_enabled"/>
                        </setting>
                        <setting string="AI у чаті сайту (Odoo Live Chat)" help="Якщо вимкнено, бот не відповідає у live chat на сайті, навіть коли LLM загалом увімкнений.">
                            <field name="omnichannel_site_livechat_enabled"/>
                        </setting>
                        <setting string="Бекенд">
                            <field name="omnichannel_llm_backend"/>
                        </setting>
                        <setting string="Суворе підґрунтя" help="Модель отримує лише FACTS_FROM_DATABASE з Python/Odoo; інструкція забороняє вигадувати ціни та місця.">
                            <field name="omnichannel_llm_strict_grounding"/>
                        </setting>
                        <setting string="Контекст: останні повідомлення треду" help="Марковано як не фінансова правда; для зв’язності діалогу.">
                            <field name="omnichannel_llm_include_transcript"/>
                        </setting>
                        <setting string="Скільки останніх повідомлень">
                            <field name="omnichannel_llm_transcript_messages"/>
                        </setting>
                        <setting string="Debug джерел фактів" help="Додає технічний блок DATA_SOURCES_DEBUG у контекст LLM (для внутрішньої валідації).">
                            <field name="omnichannel_llm_debug_data_sources"/>
                        </setting>
                        <setting string="Ollama URL">
                            <field name="omnichannel_ollama_base_url"/>
                        </setting>
                        <setting string="Ollama model">
                            <field name="omnichannel_ollama_model"/>
                        </setting>
                        <setting string="OpenAI API key" help="Лише якщо бекенд = OpenAI.">
                            <field name="omnichannel_openai_api_key" password="True"/>
                        </setting>
                        <setting string="OpenAI model">
                            <field name="omnichannel_openai_model"/>
                        </setting>
                        <setting string="Legacy OpenAI toggle" help="Якщо увімкнено без llm_enabled — LLM вважається увімкненим (зворотна сумісність).">
                            <field name="omnichannel_openai_enabled"/>
                        </setting>
                        <setting string="Базовий системний промпт">
                            <field name="omnichannel_openai_system_prompt" placeholder="Тон, емпатія, сценарій продажу — без вигаданих цифр (їх дає блок фактів)."/>
                        </setting>
                    </block>
                    <block title="Sales objections playbook" name="omnichannel_block_objections">
                        <setting string="Price objection">
                            <field name="omnichannel_objection_playbook_price" placeholder="Empathize, use ORM facts only, ask one budget-calibration question."/>
                        </setting>
                        <setting string="Timing objection">
                            <field name="omnichannel_objection_playbook_timing" placeholder="Respect timing, suggest low-friction next step, no pressure."/>
                        </setting>
                        <setting string="Trust objection">
                            <field name="omnichannel_objection_playbook_trust" placeholder="Use only verifiable links/facts, offer manager handoff."/>
                        </setting>
                        <setting string="Need to think">
                            <field name="omnichannel_objection_playbook_need_to_think" placeholder="Clarify blocker and answer one concrete concern with facts."/>
                        </setting>
                        <setting string="Competitor objection">
                            <field name="omnichannel_objection_playbook_competitor" placeholder="Do not attack competitors; compare only own offer from ORM/legal links."/>
                        </setting>
                        <setting string="Not decision maker">
                            <field name="omnichannel_objection_playbook_not_decision_maker" placeholder="Ask who decides and suggest a convenient handoff/call slot."/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>

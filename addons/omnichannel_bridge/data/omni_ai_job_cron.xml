<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_omni_ai_job_processor" model="ir.cron">
        <field name="name">Omnichannel AI Job Processor</field>
        <field name="model_id" ref="model_omni_ai_job"/>
        <field name="state">code</field>
        <field name="code">model.omni_cron_process_jobs()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
